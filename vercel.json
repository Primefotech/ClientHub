{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/v1/:match*",
      "destination": "/api/index.ts"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "apps/api/prisma/schema.prisma"
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/login",
      "permanent": false
    }
  ]
}
