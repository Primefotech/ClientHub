# ==========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ==========================================
# INSTRUCTIONS:
# 1. Provide these values in your Cloud Provider's environment settings (Vercel, Railway, etc.)
# 2. For Vercel Web: set NEXT_PUBLIC_API_URL to your backend URL.
# ==========================================

# Timezone
TZ=Asia/Kolkata

# Database Configuration (Docker Internal)
DB_USER=brandbook
DB_PASSWORD=brandbook_secret
DB_NAME=brandbook_client_os
DATABASE_URL="postgresql://brandbook:brandbook_secret@postgres:5432/brandbook_client_os"

# JWT Auth
JWT_SECRET="generate_a_long_random_string_here_for_security"
JWT_EXPIRES_IN="7d"

# App
PORT=3001
NODE_ENV=production

# ==========================================
# 🚨 CRITICAL: PUBLIC URLs (HTTPS) 🚨
# These MUST be reachable by your browser.
# ==========================================
FRONTEND_URL=https://your-app-frontend.vercel.app
NEXT_PUBLIC_API_URL=https://your-api-backend.com/api/v1
NEXT_PUBLIC_WS_URL=https://your-api-backend.com

# Storage (MinIO)
# Docker Internal Endpoint (Do not change)
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=brandbook
STORAGE_SECRET_KEY=brandbook_secret
STORAGE_BUCKET=brandbook-files
STORAGE_REGION=us-east-1

# Redis Cache
REDIS_HOST=redis
REDIS_PORT=6379

# WhatsApp Cloud API (Optional)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Email (SendGrid / SMTP) (Optional)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
EMAIL_FROM=noreply@brandbook.com

