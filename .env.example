# ==========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ==========================================
# INSTRUCTIONS:
# 1. Copy this content to a file named `.env` on your VPS.
# 2. Replace `<YOUR_VPS_IP>` with your actual server IP address or domain.
# 3. Save the file and run: docker compose up -d --build
# ==========================================

# Database Configuration (Docker Internal)
# Do NOT change these unless you want to change the database credentials
DB_USER=brandbook
DB_PASSWORD=brandbook_secret
DB_NAME=brandbook_client_os
DATABASE_URL="postgresql://brandbook:brandbook_secret@postgres:5432/brandbook_client_os"

# JWT Auth
JWT_SECRET="generate_a_long_random_string_here_for_security"
JWT_EXPIRES_IN="7d"

# App
PORT=3001
NODE_ENV=production

# ==========================================
# 🚨 CRITICAL: PUBLIC URLs 🚨
# These MUST be reachable by your browser.
# Defaults are set to the current VPS IP: 72.61.172.138
# ==========================================
FRONTEND_URL=http://72.61.172.138:3000
NEXT_PUBLIC_API_URL=http://72.61.172.138:3001/api/v1
NEXT_PUBLIC_WS_URL=http://72.61.172.138:3001

# Storage (MinIO)
# Docker Internal Endpoint (Do not change)
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=brandbook
STORAGE_SECRET_KEY=brandbook_secret
STORAGE_BUCKET=brandbook-files
STORAGE_REGION=us-east-1

# Redis Cache
# Docker Internal Endpoint (Do not change)
REDIS_HOST=redis
REDIS_PORT=6379

# WhatsApp Cloud API (Optional)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Email (SendGrid / SMTP) (Optional)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
EMAIL_FROM=noreply@brandbook.com

