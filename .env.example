# Database
# VERY IMPORTANT: When running in Docker, use 'postgres' instead of 'localhost'
DATABASE_URL="postgresql://brandbook:brandbook_secret@postgres:5432/brandbook_client_os"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# App
PORT=3001
NODE_ENV=production
FRONTEND_URL=http://localhost:3000

# Storage (MinIO / S3)
# Inside Docker, use http://minio:9000
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=brandbook
STORAGE_SECRET_KEY=brandbook_secret
STORAGE_BUCKET=brandbook-files
STORAGE_REGION=us-east-1

# Redis
# Inside Docker, use 'redis' instead of 'localhost'
REDIS_HOST=redis
REDIS_PORT=6379

# WhatsApp Cloud API
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Email (SendGrid / SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
EMAIL_FROM=noreply@brandbook.com

# Meta Webhooks
META_VERIFY_TOKEN=your-meta-webhook-verify-token
META_APP_SECRET=

# Google Ads
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
