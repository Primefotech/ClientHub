# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  BrandBook Client OS — Production Environment Template
#
#  SETUP:
#    cp .env.production.example .env
#    # Edit .env with your real values, then:
#    docker compose up -d --build
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_USER=brandbook
DB_PASSWORD=change_me_strong_password
DB_NAME=brandbook_client_os

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=change_me_very_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ── Your domain (used for CORS validation) ────────────────────────────────────
# This is your public-facing domain. With Nginx same-domain routing CORS is
# rarely triggered — but set this correctly for direct API access.
# Multiple domains: FRONTEND_URL=https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── MinIO file storage ────────────────────────────────────────────────────────
STORAGE_ACCESS_KEY=brandbook
STORAGE_SECRET_KEY=change_me_strong_minio_password
STORAGE_BUCKET=brandbook-files
STORAGE_REGION=us-east-1

# ── Optional: WhatsApp Cloud API ──────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ── Optional: Email (SMTP / SendGrid) ─────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com

# ── Optional: Meta Webhook ────────────────────────────────────────────────────
META_VERIFY_TOKEN=change_me_random_token
META_APP_SECRET=

# ── Optional: Google Ads ──────────────────────────────────────────────────────
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
