generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String                 @id @default(cuid())
  email             String                 @unique
  password          String
  name              String
  role              Role
  phone             String?
  avatar            String?
  isActive          Boolean                @default(true)
  lastLoginAt       DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  activityLogs      ActivityLog[]
  approvalActions   ApprovalLog[]
  sentComments      Comment[]
  contentTypes      ContentType[]          @relation("CreatedContentTypes")
  uploadedCreatives Creative[]             @relation("UploadedBy")
  assignedLeads     CRMLead[]              @relation("AssignedTo")
  createdLeads      CRMLead[]              @relation("CreatedBy")
  notifications     Notification[]
  onboardingEdits   OnboardingFieldEdit[]
  projectUsers      ProjectUser[]
  tenantUsers       TenantUser[]
  createdThreads    Thread[]
  createdUpsells    UpsellRecommendation[]
  webhookConfigs    WebhookConfig[]

  @@map("users")
}

model Tenant {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  logo          String?
  domain        String?
  industry      String?
  isActive      Boolean         @default(true)
  settings      Json            @default("{}")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  notifications Notification[]
  projects      Project[]
  tenantUsers   TenantUser[]
  webhooks      WebhookConfig[]

  @@map("tenants")
}

model TenantUser {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@map("tenant_users")
}

model Project {
  id              String                 @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  status          String                 @default("ACTIVE")
  color           String?
  icon            String?
  settings        Json                   @default("{}")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  activityLogs    ActivityLog[]
  adReports       AdReport[]
  approvalRules   ApprovalRule[]
  calendarEvents  CalendarEvent[]
  contentTypes    ContentType[]
  creatives       Creative[]
  crmLeads        CRMLead[]
  onboardingForms OnboardingForm[]
  projectUsers    ProjectUser[]
  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ruleConfigs     RuleEngineConfig[]
  threads         Thread[]
  upsells         UpsellRecommendation[]

  @@map("projects")
}

model ProjectUser {
  id          String   @id @default(cuid())
  projectId   String
  userId      String
  role        Role
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_users")
}

model ContentType {
  id                      String     @id @default(cuid())
  name                    String
  description             String?
  isGlobal                Boolean    @default(false)
  projectId               String?
  fields                  Json       @default("[]")
  defaultApprovalRequired Boolean    @default(true)
  defaultAutoApprove      Boolean    @default(false)
  autoApproveAfterHours   Int?
  icon                    String?
  color                   String?
  createdById             String?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  isArchived              Boolean    @default(false)
  archivedAt              DateTime?
  createdBy               User?      @relation("CreatedContentTypes", fields: [createdById], references: [id])
  project                 Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creatives               Creative[]

  @@map("content_types")
}

model Creative {
  id               String            @id @default(cuid())
  projectId        String
  contentTypeId    String?
  title            String
  description      String?
  fileUrl          String?
  thumbnailUrl     String?
  fileType         String
  mimeType         String?
  fileSize         Int?
  status           ContentStatus     @default(DRAFT)
  requiresApproval Boolean           @default(true)
  scheduledAt      DateTime?
  publishedAt      DateTime?
  tags             String[]
  metadata         Json              @default("{}")
  uploadedById     String
  versionNumber    Int               @default(1)
  parentId         String?
  isLatestVersion  Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  approvalRequests ApprovalRequest[]
  calendarEvents   CalendarEvent[]
  contentType      ContentType?      @relation(fields: [contentTypeId], references: [id])
  parent           Creative?         @relation("Versions", fields: [parentId], references: [id])
  versions         Creative[]        @relation("Versions")
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy       User              @relation("UploadedBy", fields: [uploadedById], references: [id])
  threads          Thread[]

  @@map("creatives")
}

model ApprovalRule {
  id                       String   @id @default(cuid())
  projectId                String
  contentTypeId            String?
  name                     String
  requiresApproval         Boolean  @default(true)
  approvalDeadlineHours    Int?
  autoApproveAfterDeadline Boolean  @default(false)
  requiresPHApproval       Boolean  @default(false)
  requiresClientApproval   Boolean  @default(true)
  isLocked                 Boolean  @default(false)
  lockedById               String?
  priority                 Int      @default(0)
  conditions               Json     @default("{}")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("approval_rules")
}

model ApprovalRequest {
  id            String        @id @default(cuid())
  creativeId    String
  requestedById String
  status        ContentStatus @default(PENDING_APPROVAL)
  deadline      DateTime?
  notes         String?
  round         Int           @default(1)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  approvalLogs  ApprovalLog[]
  creative      Creative      @relation(fields: [creativeId], references: [id], onDelete: Cascade)

  @@map("approval_requests")
}

model ApprovalLog {
  id                String          @id @default(cuid())
  approvalRequestId String
  actionById        String
  action            ApprovalAction
  comment           String?
  attachments       String[]
  timeTakenMinutes  Int?
  createdAt         DateTime        @default(now())
  actionBy          User            @relation(fields: [actionById], references: [id])
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)

  @@map("approval_logs")
}

model Thread {
  id          String    @id @default(cuid())
  projectId   String
  creativeId  String?
  title       String?
  type        String    @default("content")
  isResolved  Boolean   @default(false)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comments    Comment[]
  createdBy   User      @relation(fields: [createdById], references: [id])
  creative    Creative? @relation(fields: [creativeId], references: [id])
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("threads")
}

model Comment {
  id          String    @id @default(cuid())
  threadId    String
  authorId    String
  content     String
  attachments String[]
  mentions    String[]
  isEdited    Boolean   @default(false)
  parentId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User      @relation(fields: [authorId], references: [id])
  parent      Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies     Comment[] @relation("Replies")
  thread      Thread    @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model CRMLead {
  id           String           @id @default(cuid())
  projectId    String
  source       LeadSource       @default(MANUAL)
  webhookId    String?
  name         String
  email        String?
  phone        String?
  company      String?
  status       LeadStatus       @default(NEW)
  assignedToId String?
  createdById  String
  notes        String?
  customFields Json             @default("{}")
  tags         String[]
  value        Float?
  currency     String           @default("USD")
  lostReason   String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  history      CRMLeadHistory[]
  assignedTo   User?            @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy    User             @relation("CreatedBy", fields: [createdById], references: [id])
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("crm_leads")
}

model CRMLeadHistory {
  id          String   @id @default(cuid())
  leadId      String
  changedById String
  field       String
  oldValue    String?
  newValue    String?
  note        String?
  createdAt   DateTime @default(now())
  lead        CRMLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("crm_lead_history")
}

model AdReport {
  id           String   @id @default(cuid())
  projectId    String
  platform     String
  campaignName String?
  campaignId   String?
  dateFrom     DateTime
  dateTo       DateTime
  spend        Float    @default(0)
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  leads        Int      @default(0)
  conversions  Int      @default(0)
  revenue      Float    @default(0)
  cpl          Float?
  cpc          Float?
  ctr          Float?
  roas         Float?
  metadata     Json     @default("{}")
  isManual     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("ad_reports")
}

model OnboardingForm {
  id          String               @id @default(cuid())
  projectId   String?
  isGlobal    Boolean              @default(false)
  title       String
  description String?
  mode        OnboardingMode       @default(PH_FILLED)
  isPublished Boolean              @default(false)
  shareToken  String?              @unique
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  fields      OnboardingField[]
  project     Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  responses   OnboardingResponse[]

  @@map("onboarding_forms")
}

model OnboardingField {
  id           String                @id @default(cuid())
  formId       String
  label        String
  fieldType    FieldType             @default(TEXT)
  placeholder  String?
  helpText     String?
  isRequired   Boolean               @default(false)
  options      Json                  @default("[]")
  order        Int                   @default(0)
  sectionLabel String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  edits        OnboardingFieldEdit[]
  form         OnboardingForm        @relation(fields: [formId], references: [id], onDelete: Cascade)
  responses    OnboardingResponse[]

  @@map("onboarding_fields")
}

model OnboardingResponse {
  id        String          @id @default(cuid())
  formId    String
  fieldId   String
  value     String?
  fileUrl   String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  field     OnboardingField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  form      OnboardingForm  @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([formId, fieldId])
  @@map("onboarding_responses")
}

model OnboardingFieldEdit {
  id         String          @id @default(cuid())
  fieldId    String
  editedById String
  oldValue   String?
  newValue   String?
  createdAt  DateTime        @default(now())
  editedBy   User            @relation(fields: [editedById], references: [id])
  field      OnboardingField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@map("onboarding_field_edits")
}

model CalendarEvent {
  id          String    @id @default(cuid())
  projectId   String
  creativeId  String?
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(false)
  color       String?
  status      String    @default("SCHEDULED")
  platform    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  creative    Creative? @relation(fields: [creativeId], references: [id])
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("calendar_events")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  tenantId  String?
  type      NotificationType
  title     String
  body      String
  data      Json             @default("{}")
  isRead    Boolean          @default(false)
  readAt    DateTime?
  emailSent Boolean          @default(false)
  waSent    Boolean          @default(false)
  createdAt DateTime         @default(now())
  tenant    Tenant?          @relation(fields: [tenantId], references: [id])
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model WebhookConfig {
  id           String       @id @default(cuid())
  tenantId     String
  projectId    String?
  name         String
  event        WebhookEvent
  secretToken  String
  isActive     Boolean      @default(true)
  fieldMapping Json         @default("{}")
  createdById  String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  createdBy    User         @relation(fields: [createdById], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("webhook_configs")
}

model RuleEngineConfig {
  id        String   @id @default(cuid())
  projectId String
  module    String
  rules     Json     @default("[]")
  isLocked  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, module])
  @@map("rule_engine_configs")
}

model UpsellRecommendation {
  id             String    @id @default(cuid())
  projectId      String?
  isGlobal       Boolean   @default(false)
  title          String
  description    String
  category       String
  priority       String    @default("MEDIUM")
  status         String    @default("PENDING")
  estimatedValue Float?
  currency       String    @default("USD")
  attachments    String[]
  createdById    String
  viewedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      User      @relation(fields: [createdById], references: [id])
  project        Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("upsell_recommendations")
}

model GlobalSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json     @default("{}")
  updatedAt DateTime @updatedAt

  @@map("global_settings")
}

model ActivityLog {
  id        String   @id @default(cuid())
  projectId String?
  userId    String
  action    String
  entity    String
  entityId  String?
  details   Json     @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  project   Project? @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

enum Role {
  SUPER_ADMIN
  PROJECT_HEAD
  BRANDBOOK_STAFF
  CLIENT_OWNER
  CLIENT_STAFF
}

enum ContentStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  REVISION_REQUESTED
  SCHEDULED
  PUBLISHED
  AUTO_APPROVED
}

enum ApprovalAction {
  APPROVED
  REJECTED
  REVISION_REQUESTED
  AUTO_APPROVED
  DEADLINE_PASSED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
  ON_HOLD
}

enum LeadSource {
  WEBHOOK
  MANUAL
  IMPORT
}

enum NotificationType {
  APPROVAL_REQUEST
  APPROVAL_DECISION
  APPROVAL_DEADLINE
  COMMENT_ADDED
  LEAD_ASSIGNED
  LEAD_UPDATED
  ONBOARDING_UPDATED
  UPSELL_ADDED
  REPORT_READY
  MENTION
}

enum OnboardingMode {
  CLIENT_FILLED
  PH_FILLED
}

enum FieldType {
  TEXT
  TEXTAREA
  NUMBER
  EMAIL
  PHONE
  DATE
  SELECT
  MULTISELECT
  CHECKBOX
  FILE
  URL
}

enum WebhookEvent {
  LEAD_CREATED
  META_LEAD
  GOOGLE_LEAD
  WHATSAPP_MESSAGE
}
model Playbook {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   Json     @default("{}")
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("playbooks")
}
